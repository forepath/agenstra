{
  "name": "sbom",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "tools/sbom",
  "tags": ["type:tool", "scope:sbom"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "tools/sbom/dist",
        "main": "tools/sbom/executors/sbom/impl.ts",
        "tsConfig": "tools/sbom/tsconfig.lib.json",
        "assets": [
          {
            "input": "tools/sbom/executors/sbom",
            "glob": "schema.json",
            "output": "executors/sbom"
          }
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "tools/sbom/jest.config.ts"
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    }
  }
}
