# Environment variables for the cursor-agent
CURSOR_API_KEY=

# Environment variables for the git repository
GIT_REPOSITORY_URL=
GIT_USERNAME=
GIT_TOKEN=
GIT_PRIVATE_KEY=

# Environment variables for encryption
ENCRYPTION_KEY=

# Authentication method configuration (recommended to set explicitly; required in production)
# AUTHENTICATION_METHOD: api-key | keycloak
AUTHENTICATION_METHOD=api-key

# CORS configuration (comma-separated list of allowed origins)
# Example: CORS_ORIGIN=http://localhost:4200,http://localhost:4300
CORS_ORIGIN=http://localhost:4200,http://localhost:4300,http://localhost:4400,http://localhost:4500

# WebSocket CORS allowlist (comma-separated list of allowed origins)
WEBSOCKET_CORS_ORIGIN=http://localhost:4200,http://localhost:4300,http://localhost:4400,http://localhost:4500

# Environment variables for static API key authentication (when AUTHENTICATION_METHOD=api-key)
STATIC_API_KEY=
